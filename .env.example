# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NLP Service
# Local development: http://localhost:8001
# Production: your deployed NLP service URL (Railway, Render, etc.)
NLP_SERVICE_URL=http://localhost:8001
NLP_SERVICE_TIMEOUT=30000

# SERP API
# Get API key from SerpAPI (https://serpapi.com/), DataForSEO, or ValueSerp
# Optional: Leave empty for development/testing
SERPAPI_KEY=your_serpapi_key_here

# Redis (Cache + Rate Limiting)
# Option 1: Local Redis (development)
# REDIS_URL=redis://localhost:6379
#
# Option 2: Upstash Redis (recommended for production)
# Get these from https://console.upstash.com/
# Note: Use ioredis format, not REST API
# REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
#
# Option 3: Legacy Upstash REST API (deprecated - for backward compatibility only)
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA
#
# Optional in development, recommended in production for:
# - SERP analysis caching (24h TTL)
# - Guide content caching (5min TTL)
# - Rate limiting state
REDIS_URL=redis://localhost:6379

# Monitoring & Logging
# NODE_ENV controls log format: development (colorized) | production (JSON) | test
NODE_ENV=development

# Sentry (Error Monitoring - Optional, not required)
# Get these from https://sentry.io/
# NOTE: We currently use lightweight monitoring (structured logging + error boundaries)
# Uncomment these if you want to add Sentry integration in the future
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=serpmantic
# SENTRY_AUTH_TOKEN=your-auth-token

# NLP Service Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://app.serpmantic.com
